# Copy this file to .env and fill in your credentials
# cp .env.example .env

# Required: Your OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Optional: Override the OpenAI model used for vision analysis (default: gpt-4o)
# OPENAI_MODEL=gpt-4o

# Optional: Uvicorn host/port
# HOST=0.0.0.0
# PORT=8000
